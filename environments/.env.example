# Backend .env example for development environment

# App
NODE_ENV=development
PORT=8080
BASE_URL=http://localhost:8080
CLIENT_URL=http://localhost:3000

# PostgreSQL
POSTGRES_USER=dev
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=rythmify_dev
DATABASE_URL=postgresql://dev:devpassword@localhost:5432/rythmify_dev

# pgAdmin
PGADMIN_EMAIL=your_email_here
PGADMIN_PASSWORD=your_pgadmin_password_here

# Azurite (blob storage)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OcuhHHH4a+GCKoV9wJ5Lw==;BlobEndpoint=http://rythmify_blob:10000/devstoreaccount1;
BLOB_CONTAINER_AUDIO=audio
BLOB_CONTAINER_MEDIA=media

# JWT
JWT_SECRET=your_jwt_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:8080/api/v1/auth/google/callback

# SoundCloud OAuth
SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id_here
SOUNDCLOUD_CLIENT_SECRET=your_soundcloud_client_secret_here

# Email
GMAIL_USER=your_gmail_here
GMAIL_APP_PASSWORD=your_gmail_app_password_here
EMAIL_FROM=Rythmify <your_gmail_here>

# reCAPTCHA
RECAPTCHA_SECRET=your_recaptcha_secret_here

# Stripe 
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Frontend 
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_USE_MOCK=false
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_APP_URL=http://localhost:5173
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_secret_here
VITE_APP_NAME=Rhythmify